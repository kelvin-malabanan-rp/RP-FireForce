{
  "expo": {
    "name": "RP-Fireforce-Pager",
    "slug": "RP-Fireforce-Pager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rp-ff-icon-with-bg.png",
    "scheme": "rpfireforcepager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rocketpartners.rpfireforcepager"
    },
    "android": {
      "package": "com.rocketpartners.rpfireforcepager",
      "adaptiveIcon": {
        "backgroundColor": "#1da0d6",
        "foregroundImage": "./assets/images/notification-icon.png",
        "backgroundImage": "./assets/images/notification-icon.png",
        "monochromeImage": "./assets/images/notification-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/notification-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1da0d6",
          "dark": {
            "backgroundColor": "#1da0d6"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1da0d6",
          "defaultChannel": "default-v4",
          "sounds": [
            "./assets/sounds/alarm_sound.mp3",
            "./assets/sounds/alarm_sound_ios.wav"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ed4b748d-8758-4d6a-999c-549c023d50d0"
      }
    },
    "owner": "rp-keannubrillante"
  }
}
