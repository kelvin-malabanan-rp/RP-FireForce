{
  "expo": {
    "name": "RP FireForce",
    "slug": "RP-Fireforce-Pager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/rp-ff-icon-with-bg.png",
    "scheme": "rpfireforcepager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rocketpartners.rpfireforcepager",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["rpfireforcepager"]
          }
        ]
      }
    },
    "android": {
      "package": "com.rocketpartners.rpfireforcepager",
      "versionCode": 1,
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "USE_FULL_SCREEN_INTENT"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/images/notification-icon.png",
        "backgroundImage": "./assets/images/notification-icon.png",
        "monochromeImage": "./assets/images/notification-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "useNextNotificationsApi": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "rpfireforcepager",
              "host": "auth",
              "pathPrefix": "/callback"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/notification-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#F97316",
          "defaultChannel": "default-v4",
          "sounds": [
            "./assets/sounds/alarm_sound.mp3",
            "./assets/sounds/alarm_critical.mp3",
            "./assets/sounds/alarm_high.mp3",
            "./assets/sounds/alarm_medium.mp3",
            "./assets/sounds/alarm_low.mp3",
            "./assets/sounds/alarm_critical_ios.wav",
            "./assets/sounds/alarm_high_ios.wav",
            "./assets/sounds/alarm_medium_ios.wav",
            "./assets/sounds/alarm_low_ios.wav",
            "./assets/sounds/alarm_sound_ios.wav"
          ]
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "ed4b748d-8758-4d6a-999c-549c023d50d0"
      },
      "googleOAuth": {
        "webClientId": "688145840657-ps40srtg7635hmegdhuehco0r9cj3qbe.apps.googleusercontent.com",
        "iosClientId": "688145840657-k8jel0co1ksul0pok9aunt0l8ddj526p.apps.googleusercontent.com",
        "androidClientId": "688145840657-2hjotef33ajs8n26cmu5ut7fmjh7n9ka.apps.googleusercontent.com"
      }
    },
    "owner": "rp-keannubrillante"
  }
}